      "type": "string"
    },
    "file_class": {
      "type": "string",
      "enum": [
        "language_root",
        "shared_meta",
        "product_ideal",
        "implementation_resolved",
        "blueprint_state",
        "process_guide",
        "exploratory_companion"
      ]
