  "additionalProperties": false,
  "required": [
    "target_file",
    "file_class",
    "evaluation_modes",
    "allowed_companion_context",
    "dimension_ratings",
    "summary",
    "strengths",
    "weaknesses",
    "recommendation",
    "confidence"
