{
  "name": "agent-infrastructure",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "./node_modules/.bin/tsgo -b tsconfig.projects.json --noEmit",
    "check": "./node_modules/.bin/tsgo -b tsconfig.projects.json --noEmit",
    "lint": "./node_modules/.bin/biome check apps packages",
    "format": "./node_modules/.bin/biome format --write apps packages",
    "connect-vscode": "bash ./tools/connect-vscode.sh --profile agent-team-admin",
    "connect-ssh": "bash ./tools/connect-ssh.sh --profile agent-team-admin",
    "agent:connect-worker-ec2-ssh": "bun run --filter @agent-infrastructure/swarm-manager run:connect-worker-ec2-ssh",
    "agent:prepare-manager-surface": "bun run --filter @agent-infrastructure/swarm-manager run:prepare-manager-surface",
    "agent:prepare-worker-surface": "bun run --filter @agent-infrastructure/swarm-manager run:prepare-worker-surface",
    "agent:merge-manager-feature": "bun run --filter @agent-infrastructure/swarm-manager run:merge-manager-feature",
    "agent:merge-worker-feature": "bun run --filter @agent-infrastructure/swarm-manager run:merge-worker-feature",
    "codex": "codex --dangerously-bypass-approvals-and-sandbox -C ~ resume --last --all",
    "dev:agent-graph": "cd apps/agentish-studio && bun run dev --host 0.0.0.0",
    "build:agent-graph": "cd apps/agentish-studio && bun run build",
    "start:agent-graph": "cd packages/agent-graph-server && bun run start",
    "dev:dashboard": "bun run --filter @agent-infrastructure/dashboard-app dev",
    "build:dashboard": "bun run --filter @agent-infrastructure/dashboard-app build",
    "codex:app-server-turn": "bun ./scripts/run-codex-app-server-turn.ts",
    "eval:agentish-quality": "bun ./scripts/evaluate-agentish-quality.ts",
    "deploy-manager-runtime": "bash ./scripts/deploy-manager-runtime.sh",
    "issue:dashboard-session": "bash ./scripts/issue-dashboard-session.sh",
    "prepare:cloudflare-tunnel": "bash ./packages/aws-setup/scripts/prepare-cloudflare-tunnel.sh",
    "github-app-token": "bash ./tools/github-app-token.sh",
    "start:dashboard": "bun run --filter @agent-infrastructure/dashboard start",
    "open:dashboard": "bun run --filter @agent-infrastructure/swarm-manager run:open-dashboard",
    "test:swarm-manager": "bun run --filter @agent-infrastructure/swarm-manager test",
    "test:local-swarm": "bash ./tools/test-local-swarm.sh",
    "synth:aws-setup": "bun run --filter @agent-infrastructure/aws-setup synth",
    "destroy:aws-setup": "bun run --filter @agent-infrastructure/aws-setup destroy"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@typescript/native-preview": "^7.0.0-dev.20260330.1"
  }
}
