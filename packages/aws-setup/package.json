{
  "name": "@agent-infrastructure/aws-setup",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json --noEmit",
    "check": "tsc --project tsconfig.json --noEmit",
    "prepare-dashboard-enrollment-secret": "bash ./scripts/prepare-dashboard-enrollment-secret.sh --stack-name ${STACK_NAME:-AgentSwarmAwsSetup}",
    "prepare-cloudflare-tunnel": "bash ./scripts/prepare-cloudflare-tunnel.sh --stack-name ${STACK_NAME:-AgentSwarmAwsSetup}",
    "synth": "bash ./scripts/run-cdk.sh synth",
    "diff": "bash ./scripts/run-cdk.sh diff",
    "deploy": "bash ./scripts/run-cdk.sh deploy",
    "destroy": "bash ./scripts/destroy-swarm.sh"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "aws-cdk": "^2.130.0",
    "@types/node": "^20.11.30",
    "esbuild": "^0.25.2",
    "typescript": "^5.4.5"
  }
}
