{
  "name": "@agent-infrastructure/swarm-manager",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun x tsgo --project tsconfig.json --noEmit",
    "check": "bun x tsgo --project tsconfig.json --noEmit",
    "test": "bun test",
    "run:manager": "bun run src/manager/server.ts",
    "run:manager-controller": "bun run src/manager/manager-controller.ts",
    "run:issue-dashboard-session": "bun run src/manager/issue-dashboard-session.ts",
    "run:open-dashboard": "bun run src/manager/open-dashboard.ts",
    "run:request-workspace-persistence": "bun run src/manager/request-workspace-persistence.ts",
    "run:update-runtime": "bun run src/manager/update-runtime.ts",
    "run:setup-manager-host": "bun run src/manager/setup-host.ts",
    "run:setup-host": "bun run src/manager/setup-host.ts",
    "run:setup-admin-host": "bun run src/admin/setup-host.ts",
    "run:setup-worker-host": "bun run src/worker/setup-host.ts",
    "run:admin-compat": "bun run src/admin/compat-server.ts",
    "run:publish-worker-runtime-release": "bun run src/manager/publish-worker-runtime-release.ts",
    "run:build-worker-image": "bun run src/manager/build-worker-image.ts",
    "run:test-worker-image-lifecycle": "bun run src/manager/test-worker-image-lifecycle.ts",
    "run:hibernate-workers": "bun run src/manager/worker-power.ts --action hibernate",
    "run:wake-workers": "bun run src/manager/worker-power.ts --action wake",
    "run:connect-worker-ec2-ssh": "bun run src/manager/connect-worker-ec2-ssh.ts",
    "run:prepare-manager-surface": "bun run src/manager/prepare-manager-surface.ts",
    "run:prepare-worker-surface": "bun run src/manager/prepare-worker-surface.ts",
    "run:merge-manager-feature": "bun run src/manager/merge-manager-feature.ts",
    "run:merge-worker-feature": "bun run src/manager/merge-feature.ts",
    "run:launch-service": "bun run src/manager/launch-service.ts",
    "run:worker-agent": "bun run src/worker/agent.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@agent-infrastructure/dashboard-app": "workspace:*"
  }
}
