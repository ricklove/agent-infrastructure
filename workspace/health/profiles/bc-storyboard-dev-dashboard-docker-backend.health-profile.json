{
  "id": "bc_storyboard_dev_dashboard_docker_backend",
  "title": "BaseConnect onboarding storyboard health \u2014 docker backend",
  "description": "Cold-start top-level health profile for the full DEV Storyboard + BaseConnect onboarding path with frontend runtime configured against the Docker/local backend stack. Reuses the shared Storyboard/dashboard cold-start health template while keeping the Docker backend branch independent from staging.",
  "runLocation": {
    "executor": "dashboard-health-api",
    "workTarget": "agent-infra-dev/ddev-dashboard",
    "host": "ddev worker dashboard surface",
    "source": "dashboard server initiating delegated cross-surface probes",
    "vantagePoint": "ddev worker dashboard API",
    "providerType": "workflow-rollup-template"
  },
  "params": {
    "backendMode": "docker",
    "runTargetId": "baseconnect-frontend-web",
    "localDashboardUrl": "http://127.0.0.1:3300",
    "publicDashboardUrl": "",
    "viteUrl": "http://127.0.0.1:5173",
    "expectedMinimumPassCount": "27",
    "timeoutSeconds": "8",
    "storyboardUrl": "{{storyboardUrl}}",
    "frontendUrl": "{{frontendUrl}}",
    "backendApiUrl": "{{backendApiUrl}}",
    "bcFrontendQuickTunnelUrl": "{{bcFrontendQuickTunnelUrl}}",
    "bcFrontendQuickTunnelStateUrl": "{{bcFrontendQuickTunnelStateUrl}}",
    "runtimeSettingsTimeoutMs": "2000",
    "runtimeSettings": {
      "maxAgeSeconds": 900,
      "required": [
        "storyboardUrl",
        "frontendUrl",
        "backendApiUrl"
      ],
      "sources": [
        {
          "id": "bc-storyboard-source",
          "path": "{{stateRoot}}/runtime-settings/bc-storyboard/onboarding.json",
          "required": [
            "storyboardUrl"
          ],
          "valueMap": {
            "storyboardUrl": "storyboardUrl",
            "sourceUrl": "storyboardUrl"
          }
        },
        {
          "id": "bc-frontend-docker-runtime",
          "path": "{{stateRoot}}/runtime-settings/bc-frontend/docker.json",
          "required": [
            "frontendUrl"
          ],
          "valueMap": {
            "frontendUrl": "frontendUrl",
            "privateBaseUrl": "frontendUrl",
            "bcFrontendQuickTunnelUrl": "bcFrontendQuickTunnelUrl",
            "quickTunnelUrl": "bcFrontendQuickTunnelUrl",
            "bcFrontendQuickTunnelStateUrl": "bcFrontendQuickTunnelStateUrl",
            "quickTunnelStateUrl": "bcFrontendQuickTunnelStateUrl",
            "backendApiUrl": "backendApiUrl"
          }
        }
      ]
    }
  },
  "checks": [
    {
      "id": "bc_storyboard_dev_dashboard_docker_backend_cold_start",
      "checkId": "storyboard_cold_start_dev_dashboard_backend",
      "title": "BaseConnect onboarding storyboard can recover from cold start",
      "component": "bc-storyboard on dev dashboard with docker backend",
      "runLocation": {
        "executor": "dashboard-health-api",
        "workTarget": "agent-infra-dev/ddev-dashboard",
        "host": "ddev worker dashboard surface",
        "source": "dashboard server initiated workflow health",
        "vantagePoint": "ddev worker dashboard API -> Docker/backend parent",
        "providerType": "workflow-rollup-template"
      },
      "severity": "blocking",
      "repairHint": "Repair the failing child owner shown in the tree: bc-frontend should start the Docker web app/backend surfaces without falling back to staging; bc-storyboard should restore the storyboard source/check-all endpoint; ddev-storyboard should restore the Health Dashboard or storyboard editor route. Current resolved URLs belong in row details/evidence only; no fake repair button is exposed here.",
      "params": {
        "backendMode": "{{backendMode}}",
        "storyboardUrl": "{{storyboardUrl}}",
        "runTargetId": "{{runTargetId}}",
        "frontendUrl": "{{frontendUrl}}",
        "backendApiUrl": "{{backendApiUrl}}",
        "localDashboardUrl": "{{localDashboardUrl}}",
        "publicDashboardUrl": "{{publicDashboardUrl}}",
        "viteUrl": "{{viteUrl}}",
        "expectedMinimumPassCount": "{{expectedMinimumPassCount}}",
        "bcFrontendQuickTunnelUrl": "{{bcFrontendQuickTunnelUrl}}",
        "bcFrontendQuickTunnelStateUrl": "{{bcFrontendQuickTunnelStateUrl}}",
        "timeoutSeconds": "{{timeoutSeconds}}"
      }
    }
  ]
}
