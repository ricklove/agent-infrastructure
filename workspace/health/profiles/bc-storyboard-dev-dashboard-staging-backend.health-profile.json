{
  "id": "bc_storyboard_dev_dashboard_staging_backend",
  "title": "BaseConnect onboarding storyboard health \u2014 staging backend",
  "description": "Cold-start top-level health profile for the full DEV Storyboard + BaseConnect onboarding path: bc-storyboard source, ddev dashboard remote-storyboard route, and BaseConnect frontend staging backend runtime.",
  "runLocation": {
    "executor": "dashboard-health-api",
    "workTarget": "agent-infra-dev/ddev-dashboard",
    "host": "ddev worker dashboard surface",
    "source": "dashboard server initiating cross-surface probes",
    "vantagePoint": "ddev worker dashboard API",
    "providerType": "workflow-rollup"
  },
  "params": {
    "backendMode": "staging",
    "runTargetId": "baseconnect-frontend-web",
    "localDashboardUrl": "http://127.0.0.1:3300",
    "publicDashboardUrl": "",
    "viteUrl": "http://127.0.0.1:5173",
    "expectedMinimumPassCount": "27",
    "timeoutSeconds": "8",
    "storyboardUrl": "{{storyboardUrl}}",
    "frontendUrl": "{{frontendUrl}}",
    "bcFrontendQuickTunnelUrl": "{{bcFrontendQuickTunnelUrl}}",
    "bcFrontendQuickTunnelStateUrl": "{{bcFrontendQuickTunnelStateUrl}}",
    "runtimeSettingsTimeoutMs": "2000",
    "runtimeSettings": {
      "maxAgeSeconds": 900,
      "required": [
        "storyboardUrl",
        "frontendUrl"
      ],
      "sources": [
        {
          "id": "bc-storyboard-source",
          "path": "{{stateRoot}}/runtime-settings/bc-storyboard/onboarding.json",
          "required": [
            "storyboardUrl"
          ],
          "valueMap": {
            "storyboardUrl": "storyboardUrl",
            "sourceUrl": "storyboardUrl"
          }
        },
        {
          "id": "bc-frontend-staging-runtime",
          "path": "{{stateRoot}}/runtime-settings/bc-frontend/staging.json",
          "required": [
            "frontendUrl"
          ],
          "valueMap": {
            "frontendUrl": "frontendUrl",
            "privateBaseUrl": "frontendUrl",
            "bcFrontendQuickTunnelUrl": "bcFrontendQuickTunnelUrl",
            "quickTunnelUrl": "bcFrontendQuickTunnelUrl",
            "bcFrontendQuickTunnelStateUrl": "bcFrontendQuickTunnelStateUrl",
            "quickTunnelStateUrl": "bcFrontendQuickTunnelStateUrl"
          }
        }
      ]
    }
  },
  "checks": [
    {
      "id": "bc_storyboard_dev_dashboard_staging_backend_cold_start",
      "checkId": "storyboard_cold_start_dev_dashboard_backend",
      "title": "BaseConnect onboarding storyboard can recover from cold start",
      "component": "bc-storyboard on dev dashboard with staging backend",
      "runLocation": {
        "executor": "dashboard-health-api",
        "workTarget": "agent-infra-dev/ddev-dashboard",
        "host": "ddev worker dashboard surface",
        "source": "dashboard server initiated workflow health",
        "vantagePoint": "ddev worker dashboard API",
        "providerType": "workflow-rollup"
      },
      "severity": "blocking",
      "repairHint": "Repair the failing child owner shown in the tree: bc-frontend should start the staging web app runtime with the staging backend API and publish its current URL; bc-storyboard should restore the storyboard source/check-all endpoint; ddev-storyboard should restore the Health Dashboard or storyboard editor route. Current resolved URLs belong in row details/evidence only; no fake repair action is exposed here.",
      "params": {
        "backendMode": "{{backendMode}}",
        "storyboardUrl": "{{storyboardUrl}}",
        "runTargetId": "{{runTargetId}}",
        "frontendUrl": "{{frontendUrl}}",
        "localDashboardUrl": "{{localDashboardUrl}}",
        "publicDashboardUrl": "{{publicDashboardUrl}}",
        "viteUrl": "{{viteUrl}}",
        "expectedMinimumPassCount": "{{expectedMinimumPassCount}}",
        "bcFrontendQuickTunnelUrl": "{{bcFrontendQuickTunnelUrl}}",
        "bcFrontendQuickTunnelStateUrl": "{{bcFrontendQuickTunnelStateUrl}}",
        "timeoutSeconds": "{{timeoutSeconds}}"
      }
    }
  ]
}
