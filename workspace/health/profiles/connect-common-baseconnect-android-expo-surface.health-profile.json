{
  "id": "connect_common_baseconnect_android_expo_surface",
  "title": "Connect Common Baseconnect Android Expo Surface",
  "description": "Consolidated Baseconnect Android Expo worker health profile for device/app readiness plus real staging bot login verification.",
  "params": {
    "authEnvPath": "/home/ec2-user/.baseconnect-staging-bot.env"
  },
  "checks": [
    {
      "id": "target_reachable",
      "checkId": "work_at_target_reachable",
      "title": "work-at target is reachable",
      "severity": "blocking",
      "params": {}
    },
    {
      "id": "target_path_exists",
      "checkId": "work_at_path_exists",
      "title": "Registered Android repo path exists",
      "severity": "blocking",
      "params": {
        "path": "{{targetPath}}"
      }
    },
    {
      "id": "target_git_root_present",
      "checkId": "work_at_git_root_present",
      "title": "Registered Android repo path is a git checkout",
      "severity": "blocking",
      "params": {
        "repoPath": "{{targetPath}}"
      }
    },
    {
      "id": "target_git_origin_readable",
      "checkId": "work_at_git_origin_readable",
      "title": "Registered Android repo can read from origin",
      "severity": "blocking",
      "params": {
        "repoPath": "{{targetPath}}"
      }
    },
    {
      "id": "target_package_json_present",
      "checkId": "work_at_path_exists",
      "title": "Registered Android repo package.json exists",
      "severity": "blocking",
      "params": {
        "path": "{{targetPath}}/package.json"
      }
    },
    {
      "id": "target_expo_app_exists",
      "checkId": "work_at_path_exists",
      "title": "apps/expo-app exists on target",
      "severity": "blocking",
      "params": {
        "path": "{{targetPath}}/apps/expo-app"
      }
    },
    {
      "id": "target_java_available",
      "checkId": "work_at_command_available",
      "title": "Java is available on target",
      "severity": "blocking",
      "params": {
        "commandName": "java"
      }
    },
    {
      "id": "target_adb_available",
      "checkId": "work_at_command_available",
      "title": "ADB is available on target",
      "severity": "blocking",
      "params": {
        "commandName": "adb"
      }
    },
    {
      "id": "target_agent_device_available",
      "checkId": "work_at_command_available",
      "title": "agent-device is available on target",
      "severity": "blocking",
      "params": {
        "commandName": "agent-device"
      }
    },
    {
      "id": "target_npx_available",
      "checkId": "work_at_command_available",
      "title": "npx is available on target",
      "severity": "blocking",
      "params": {
        "commandName": "npx"
      }
    },
    {
      "id": "target_adb_device_present",
      "checkId": "work_at_adb_device_present",
      "title": "ADB sees at least one device on target",
      "severity": "blocking",
      "params": {}
    },
    {
      "id": "target_bot_auth_file_present",
      "checkId": "work_at_path_exists",
      "title": "Worker-local Baseconnect staging bot auth file exists",
      "severity": "blocking",
      "repairHint": "Create /home/ec2-user/.baseconnect-staging-bot.env on the worker with BASECONNECT_EMAIL, BASECONNECT_PASSWORD, BC_TEST_BOT_EMAIL, BC_TEST_BOT_PASSWORD, and BC_TEST_BOT_NAME before using the Baseconnect Android Expo health profile.",
      "params": {
        "path": "{{authEnvPath}}"
      }
    },
    {
      "id": "target_baseconnect_android_login_ready",
      "checkId": "work_at_baseconnect_android_login_ready",
      "title": "Android worker can boot Expo and log in to Baseconnect staging",
      "severity": "blocking",
      "params": {}
    }
  ]
}
