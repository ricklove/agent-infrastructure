{
  "id": "work_at_dashboard_app_live_dev_surface",
  "title": "Health Dashboard live dev surface",
  "description": "Health profile for the manager-served Health Dashboard surface. It verifies the current dashboard build and public route without requiring the separate ddev dashboard instance to be running.",
  "runLocation": {
    "executor": "dashboard-health-api",
    "workTarget": "manager-dashboard",
    "host": "manager dashboard surface",
    "source": "manager dashboard runtime",
    "vantagePoint": "manager dashboard API",
    "providerType": "dashboard-builtin"
  },
  "params": {
    "appPath": "{{repoRoot}}/apps/dashboard-app",
    "managerDashboardUrl": "{{requestOrigin}}",
    "liveDevMustContain": "Agent Dashboard"
  },
  "checks": [
    {
      "id": "target_reachable",
      "checkId": "work_at_target_reachable",
      "title": "Manager dashboard worker is reachable",
      "component": "manager dashboard runtime",
      "severity": "blocking",
      "params": {}
    },
    {
      "id": "target_package_json_exists",
      "checkId": "work_at_path_exists",
      "title": "Dashboard app package is present",
      "component": "manager dashboard runtime",
      "severity": "blocking",
      "params": {
        "path": "{{appPath}}/package.json"
      }
    },
    {
      "id": "target_build_assets_exist",
      "checkId": "work_at_path_exists",
      "title": "Dashboard production build is present",
      "component": "manager dashboard runtime",
      "severity": "blocking",
      "params": {
        "path": "{{repoRoot}}/apps/dashboard-app/dist/index.html"
      }
    },
    {
      "id": "manager_health_route_ok",
      "checkId": "work_at_http_status_prefix_contains",
      "title": "Manager Health Dashboard route is reachable",
      "component": "manager dashboard public route",
      "severity": "blocking",
      "params": {
        "url": "{{managerDashboardUrl}}/health",
        "timeoutSeconds": "5",
        "method": "GET",
        "curlArgs": "",
        "expectedStatusPrefix": "2",
        "mustContain": "{{liveDevMustContain}}"
      }
    },
    {
      "id": "manager_health_api_ok",
      "checkId": "work_at_http_status_prefix_contains",
      "title": "Manager Health API is reachable",
      "component": "manager dashboard API",
      "severity": "blocking",
      "params": {
        "url": "{{managerDashboardUrl}}/api/health",
        "timeoutSeconds": "5",
        "method": "GET",
        "curlArgs": "",
        "expectedStatusPrefix": "2",
        "mustContain": "\"ok\":true"
      }
    }
  ]
}
